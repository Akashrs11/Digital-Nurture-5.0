-BEGIN
-
-    UPDATE Employees
-    SET Salary = Salary + (Salary * increase_percent/100)
-    WHERE EmployeeID = emp_id;
-
-
-    IF SQL%ROWCOUNT = 0 THEN
-        RAISE_APPLICATION_ERROR(-20002,
-        'Employee does not exist');
-    END IF;
-
-
-    COMMIT;
-
-
-EXCEPTION
-
-WHEN OTHERS THEN
-
-    DBMS_OUTPUT.PUT_LINE(
